{
  "name": "@statewalker/fsm-charts",
  "version": "0.2.5",
  "description": "HFSM Implementation",
  "keywords": [],
  "homepage": "https://github.com/statewalker/statewalker-fsm-charts",
  "author": {
    "name": "Mikhail Kotelnikov",
    "email": "mikhail.kotelnikov@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "source": "./src/index.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "jsdelivr": "./dist/index.js",
  "unpkg": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/jsdom": "catalog:",
    "@types/lodash-es": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-config-standard-with-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "catalog:",
    "jsdom": "catalog:",
    "lodash": "catalog:",
    "lodash-es": "catalog:",
    "tsup": "catalog:",
    "typescript": "*",
    "vitest": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:statewalker/statewalker-fsm-charts.git"
  },
  "scripts": {
    "build": "rm -fr ./dist && pnpm test && tsup",
    "watch": "tsup --watch",
    "watch-for-viewer": "tsup --watch --outDir=../statewalker-fsm-viewer/src/.observablehq/cache/_node/@statewalker/fsm-charts@0.2.1",
    "clean": "rm -rf dist",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prepublish": "pnpm build"
